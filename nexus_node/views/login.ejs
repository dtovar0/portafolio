<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | <%= settings.portal_name %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/static/css/style.css">

    <style>
        :root { --primary-color: <%= settings.portal_logo_bg %>; }
        body {
            background: #0f172a;
            display: flex; align-items: center; justify-content: center;
            height: 100vh; margin: 0; overflow: hidden;
        }
        .login-card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(20px);
            padding: 3rem; border-radius: 32px;
            width: 100%; max-width: 420px;
            border: 1px solid rgba(255,255,255,0.1);
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-circle" style="background: <%= settings.portal_logo_bg %>; width: 64px; height: 64px; margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; border-radius: 20px; font-size: 1.5rem; color: white;">
            <i class="fas <%= settings.portal_icon %>"></i>
        </div>
        <h1 style="color: white; font-family: 'Outfit'; margin-bottom: 0.5rem;"><%= settings.portal_name %></h1>
        <p style="color: #94a3b8; font-size: 0.9rem; margin-bottom: 2rem;">Acceso al Motor Node.js Core</p>

        <% if (locals.error) { %>
            <div style="background: rgba(244, 63, 94, 0.1); color: #fb7185; padding: 1rem; border-radius: 12px; font-size: 0.8rem; margin-bottom: 1.5rem; border: 1px solid rgba(244,63,94,0.2);">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="form-group" style="text-align: left; margin-bottom: 1.5rem;">
                <label style="color: #94a3b8; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem; display: block;">Email</label>
                <div class="input-with-icon">
                    <input type="email" name="email" class="form-control" placeholder="admin@nexus.local" required style="background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(255,255,255,0.1); color: white; padding-left: 3rem;">
                    <i class="fas fa-envelope" style="position: absolute; left: 1.25rem; top: 50%; transform: translateY(-50%); color: #64748b;"></i>
                </div>
            </div>

            <div class="form-group" style="text-align: left; margin-bottom: 2rem;">
                <label style="color: #94a3b8; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem; display: block;">Contraseña</label>
                <div class="input-with-icon">
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required style="background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(255,255,255,0.1); color: white; padding-left: 3rem;">
                    <i class="fas fa-lock" style="position: absolute; left: 1.25rem; top: 50%; transform: translateY(-50%); color: #64748b;"></i>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; border-radius: 14px; font-weight: 700; background: <%= settings.portal_logo_bg %>; border: none; color: white; cursor: pointer;">
                Entrar al Portal <i class="fas fa-arrow-right" style="margin-left: 0.5rem;"></i>
            </button>
        </form>
    </div>
</body>
</html>
