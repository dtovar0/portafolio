<div class="module-header-premium">
<%
function auditBadge(action) {
    const success = ['Alta','Aprobado','Activación','Aprobación','Creación','Registro'];
    const warning = ['Pendiente','Modificación','Edición','Actualización'];
    const danger  = ['Baja','Rechazado','Revocado','Eliminación','Borrado'];
    if (success.includes(action)) return { cls: 'badge-success', icon: 'fa-check-circle' };
    if (warning.includes(action)) {
        const isPen = action === 'Pendiente';
        return { cls: 'badge-warning', icon: isPen ? 'fa-clock' : 'fa-pen' };
    }
    if (danger.includes(action))  return { cls: 'badge-danger',  icon: 'fa-times-circle' };
    return { cls: 'badge-info', icon: 'fa-info-circle' };
}
function fmtDate(d) {
    if (!d) return '-';
    const dt = d instanceof Date ? d : new Date(d);
    return dt.toLocaleDateString('es-MX', { day:'2-digit', month:'2-digit', year:'numeric' });
}
function fmtTime(d) {
    if (!d) return '';
    const dt = d instanceof Date ? d : new Date(d);
    return dt.toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
}
%>
<link rel="stylesheet" href="/static/css/audit.css?v=11">

<div class="audit-page-wrapper">
    <div class="audit-header mb-0">
        <div class="search-container flex-1">
            <div class="search-input-icon text-muted">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
            <input type="text" id="auditSearchInput" class="w-full search-input-with-icon js-audit-search"
                   placeholder="Filtrar por usuario, acción o entidad...">
        </div>
    </div>

    <div class="table-card">
        <div class="table-responsive" style="flex: none;">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th class="w-15">Fecha y Hora</th>
                        <th class="w-20">Usuario Responsable</th>
                        <th class="w-15">Entidad</th>
                        <th class="w-15">Acción</th>
                        <th class="w-35">Detalles del Evento</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!logs || logs.length === 0) { %>
                    <tr>
                        <td colspan="5">
                            <div class="premium-empty-state">
                                <div class="empty-state-visual">
                                    <div class="empty-state-blob"></div>
                                    <div class="empty-state-icon-wrapper"><i class="fas fa-history"></i></div>
                                </div>
                                <h3 class="empty-state-title">Historial Vacío</h3>
                                <p class="empty-state-text">No hay registros de auditoría en este momento. Las acciones aparecerán aquí automáticamente.</p>
                            </div>
                        </td>
                    </tr>
                    <% } else { logs.forEach(log => { const badge = auditBadge(log.action || ''); %>
                    <tr class="audit-row">
                        <td class="td-datetime">
                            <div class="fw-700 text-primary fs-sm"><%- fmtDate(log.created_at) %></div>
                            <div class="text-muted fs-xs"><%- fmtTime(log.created_at) %></div>
                        </td>
                        <td>
                            <div class="user-info-stack">
                                <span class="user-name fw-700 fs-sm text-primary"><%= log.user_name || 'Sistema' %></span>
                                <span class="user-email text-muted fs-xs"><%= log.user_email || 'nexus@access.local' %></span>
                            </div>
                        </td>
                        <td>
                            <div class="entity-info-stack">
                                <span class="entity-name fw-700 fs-sm"><%= log.entity_name || '-' %></span>
                                <span class="entity-type text-muted fs-xs"><%= log.entity_type || '-' %></span>
                            </div>
                        </td>
                        <td>
                            <span class="badge <%= badge.cls %>">
                                <i class="fas <%= badge.icon %>"></i> <%= log.action || '-' %>
                            </span>
                        </td>
                        <td>
                            <div class="audit-description-box">
                                <p class="m-0 fs-xs fw-500 text-muted"><%= log.description || '-' %></p>
                            </div>
                        </td>
                    </tr>
                    <% }); } %>
                </tbody>
            </table>
        </div>

        <% if (total_pages > 1) { %>
        <div class="pagination-footer mt-0 d-flex justify-between items-center p-1 border-top">
            <div class="pagination-info fs-xs text-muted">
                Mostrando <strong><%= logs.length %></strong> de <strong><%= total_logs %></strong> registros
            </div>
            <div class="pagination-controls d-flex gap-05">
                <a href="/admin/audit?page=<%= current_page - 1 %>"
                   class="pagination-btn <%= current_page === 1 ? 'disabled' : '' %>">
                    <i class="fas fa-chevron-left"></i> Anterior
                </a>
                <div class="pagination-numbers d-flex gap-05 items-center">
                    <span class="fs-xs fw-700">Página <%= current_page %> de <%= total_pages %></span>
                </div>
                <a href="/admin/audit?page=<%= current_page + 1 %>"
                   class="pagination-btn <%= current_page === total_pages ? 'disabled' : '' %>">
                    Siguiente <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
        <% } %>
    </div>
</div>

<script>
    window.__datos = { urls: { home: '/' } };
</script>
<script src="/static/js/audit-page.js?v=11"></script>
