<div class="settings-page-container w-full" style="margin-inline: auto;">
    <div class="settings-tabs d-flex gap-1 border-bottom-subtle">
        <button class="settings-tab active" data-action="switch-tab" data-tab="generalTab">
            <i class="fas fa-cog" style="font-size: 1.1rem;"></i> General
        </button>
        <button class="settings-tab" data-action="switch-tab" data-tab="dbTab">
            <i class="fas fa-database" style="font-size: 1.1rem;"></i> Base de Datos
        </button>
    </div>

    <form id="generalSettingsForm" class="settings-form" data-premium-validate novalidate>
        <div id="generalTab" class="tab-content active">
            <div class="branding-card">
                <div class="branding-card-header d-flex justify-between items-center w-full">
                    <h3 class="settings-title-lg">Personalización</h3>
                    <button type="submit" class="btn btn-action-new" style="height: 42px; padding: 0 1.5rem;">
                        <i class="fas fa-save" style="font-size: 1.1rem;"></i>
                        <span>Guardar Cambios</span>
                    </button>
                </div>

                <div class="branding-layout">
                    <div class="branding-left">
                        <div class="branding-portal-name">
                            <div class="section-label"><i class="fas fa-tag"></i> NOMBRE DEL PORTAL</div>
                            <div class="form-group">
                                <div class="input-with-icon">
                                    <i class="fas fa-tag"></i>
                                    <input type="text" name="portal_name" class="form-control" value="<%= settings.portal_name || 'Nexus Access' %>" placeholder="Ej: PortalTI" required>
                                </div>
                            </div>
                        </div>

                        <div class="section-label"><i class="fas fa-eye"></i> VISTA PREVIA</div>

                        <div class="preview-stage">
                            <div id="logoPreviewWrapper" class="preview-logo-frame">
                                <div id="logoPreview" class="preview-logo-box" style="background: <%= settings.portal_logo_bg || '#6366f1' %>;">
                                    <% if (settings.portal_logo_type === 'image' && settings.portal_logo_url) { %>
                                        <img src="<%= settings.portal_logo_url %>" style="width: 100%; height: 100%; object-fit: contain; padding: 15px;">
                                    <% } else if (settings.portal_logo_type === 'icon') { %>
                                        <div id="iconPreviewContainer" class="preview-icon-inner" style="color: <%= settings.portal_icon_color || '#ffffff' %>;">
                                            <i class="fas <%= settings.portal_icon || 'fa-gear' %>"></i>
                                        </div>
                                    <% } else { %>
                                        <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                    <% } %>
                                </div>
                            </div>
                            <p class="preview-caption">Esta Imagen/Icono se mostrará en el sidebar.</p>
                        </div>
                    </div>

                    <div class="branding-divider"></div>

                    <div class="branding-right">
                        <div class="section-label" style="margin-bottom: 0.4rem;"><i class="fas fa-palette"></i> TIPO DE IDENTIDAD VISUAL</div>
                        <div class="d-flex gap-1 mb-25">
                            <label class="branding-toggle-btn">
                                <input type="radio" name="portal_logo_type" value="image" class="js-branding-type" <%= settings.portal_logo_type === 'image' || !settings.portal_logo_type ? 'checked' : '' %>>
                                <div class="toggle-content"><i class="far fa-image fs-md"></i> Imagen / Logo</div>
                            </label>
                            <label class="branding-toggle-btn">
                                <input type="radio" name="portal_logo_type" value="icon" class="js-branding-type" <%= settings.portal_logo_type === 'icon' ? 'checked' : '' %>>
                                <div class="toggle-content"><i class="fas fa-shapes fs-md"></i> Icono IT</div>
                            </label>
                        </div>

                        <div id="imageUploadSection" class="<%= settings.portal_logo_type === 'icon' ? 'is-hidden' : '' %>" style="margin-bottom: 2rem;">
                            <label class="premium-upload-zone" data-action="trigger-upload">
                                <input type="file" id="logoFileInput" name="portal_logo" class="d-none js-logo-file" accept="image/*">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <span>Seleccionar nueva imagen o logo</span>
                                <p class="settings-helper-text" style="margin-top: 5px;">Recomendado: 512x512px o SVG</p>
                            </label>
                        </div>

                        <div id="iconPickerSection" class="<%= settings.portal_logo_type !== 'icon' ? 'is-hidden' : '' %>" style="margin-bottom: 2rem;">
                            <input type="hidden" name="portal_icon" id="selectedIconInput" value="<%= settings.portal_icon || 'fa-gear' %>">
                            <div class="premium-icon-grid">
                                <% const icons = ['fa-briefcase','fa-server','fa-database','fa-shield','fa-microchip','fa-terminal','fa-cloud','fa-globe','fa-wifi','fa-code','fa-usb','fa-lock','fa-chart-simple','fa-gear','fa-user','fa-users','fa-layer-group','fa-cubes','fa-credit-card','fa-mouse-pointer','fa-desktop','fa-mobile-screen','fa-up-right-from-square','fa-bolt']; %>
                                <% icons.forEach((iconKey) => { %>
                                    <div class="premium-icon-item <%= (settings.portal_icon === iconKey || (!settings.portal_icon && iconKey === 'fa-gear')) ? 'selected' : '' %>" data-action="select-icon" data-icon="<%= iconKey %>" title="<%= iconKey %>">
                                        <i class="fas <%= iconKey %>"></i>
                                    </div>
                                <% }); %>
                            </div>
                        </div>

                        <div class="branding-colors-grid">
                            <div class="branding-color-group">
                                <div class="section-label" style="margin-bottom: 0.4rem;"><i class="fas fa-fill-drip"></i> FONDO DEL LOGO</div>
                                <div class="premium-color-picker">
                                    <div class="color-preview" id="logoBgDisplay" style="background: <%= settings.portal_logo_bg || '#6366f1' %>;"></div>
                                    <span class="color-hex-value" id="logoBgHex"><%= settings.portal_logo_bg || '#6366f1' %></span>
                                    <input type="color" name="portal_logo_bg" id="logoBgInput" class="js-color-input pos-absolute" data-type="bg" value="<%= settings.portal_logo_bg || '#6366f1' %>" style="inset: 0; opacity: 0; cursor: pointer;">
                                </div>
                                <p class="color-helper-text">Se aplica detrás del logo o icono.</p>
                            </div>
                            <div class="branding-color-group <%= settings.portal_logo_type !== 'icon' ? 'is-hidden' : '' %>" id="iconColorField">
                                <div class="section-label" style="margin-bottom: 0.4rem;"><i class="fas fa-palette"></i> COLOR DEL ÍCONO</div>
                                <div class="premium-color-picker">
                                    <div class="color-preview border-subtle" id="iconColorDisplay" style="background: <%= settings.portal_icon_color || '#ffffff' %>;"></div>
                                    <span class="color-hex-value" id="iconColorHex"><%= settings.portal_icon_color || '#ffffff' %></span>
                                    <input type="color" name="portal_icon_color" id="iconColorInput" class="js-color-input pos-absolute" data-type="icon" value="<%= settings.portal_icon_color || '#ffffff' %>" style="inset: 0; opacity: 0; cursor: pointer;">
                                </div>
                                <p class="color-helper-text">Solo aplica para modo icono.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="dbTab" class="tab-content d-none">
            <div class="settings-card settings-card-box">
                <div class="settings-section-header">
                    <div class="d-flex justify-between items-center w-full">
                        <h3 class="settings-title-lg">Infraestructura de Datos</h3>
                        <div class="d-flex items-center gap-1">
                            <button type="button" class="btn btn-action-test" data-action="test-db">
                                <i class="fas fa-vial"></i> Probar Conexión
                            </button>
                            <div class="v-divider"></div>
                            <button type="submit" class="btn btn-action-new" style="height: 42px; padding: 0 1.5rem;">
                                <i class="fas fa-save" style="font-size: 1.1rem;"></i>
                                <span>Guardar Cambios</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="d-grid grid-2col gap-15 mb-25">
                    <label class="db-ref-card <%= settings.db_type === 'mysql' || !settings.db_type ? 'db-ref-card--active' : '' %>">
                        <input type="radio" name="db_type" value="mysql" class="js-db-type" <%= settings.db_type === 'mysql' || !settings.db_type ? 'checked' : '' %>>
                        <div class="db-ref-icon-wrap db-ref-icon-wrap--mysql"><i class="fas fa-database"></i></div>
                        <span class="db-ref-name">MySQL / MariaDB</span>
                        <div class="db-ref-selector"></div>
                    </label>
                    <label class="db-ref-card <%= settings.db_type === 'postgres' ? 'db-ref-card--active' : '' %>">
                        <input type="radio" name="db_type" value="postgres" class="js-db-type" <%= settings.db_type === 'postgres' ? 'checked' : '' %>>
                        <div class="db-ref-icon-wrap db-ref-icon-wrap--postgres"><i class="fas fa-server"></i></div>
                        <span class="db-ref-name">PostgreSQL</span>
                        <div class="db-ref-selector"></div>
                    </label>
                </div>

                <div class="section-label"><i class="fas fa-server"></i> PARÁMETROS DE CONEXIÓN</div>
                <div class="d-grid grid-2col gap-15">
                    <div class="form-group">
                        <label class="form-label">HOST</label>
                        <div class="input-with-icon">
                            <i class="fas fa-network-wired"></i>
                            <input type="text" name="db_host" class="form-control field-tech" value="<%= settings.db_host || 'localhost' %>" placeholder="localhost" required>
                        </div>
                    </div>
                    <div class="d-grid grid-2col gap-15">
                        <div class="form-group">
                            <label class="form-label">PUERTO</label>
                            <div class="input-with-icon">
                                <i class="fas fa-plug"></i>
                                <input type="number" name="db_port" class="form-control no-spin" value="<%= settings.db_port || '3306' %>" min="1" max="65535" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">SEGURIDAD</label>
                            <div class="settings-toggle-card" style="margin-top: 0; padding: 0.5rem 1rem; height: 46px;">
                                <div class="toggle-card-info" style="flex: 1;"><span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700;">SSL / TLS</span></div>
                                <div class="toggle-card-action">
                                    <label class="toggle-switch-ios" style="transform: scale(0.85);">
                                        <input type="checkbox" name="db_ssl" <%= settings.db_ssl ? 'checked' : '' %>>
                                        <span class="slider"></span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">NOMBRE DE LA BASE DE DATOS (ESQUEMA)</label>
                        <div class="input-with-icon">
                            <i class="fas fa-database"></i>
                            <input type="text" name="db_name" class="form-control field-tech" value="<%= settings.db_name || 'nexus_access' %>" required>
                        </div>
                    </div>
                </div>

                <div class="section-label mt-2"><i class="fas fa-lock"></i> CREDENCIALES DE ACCESO</div>
                <div class="d-grid grid-2col gap-15">
                    <div class="form-group">
                        <label class="form-label">USUARIO</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user"></i>
                            <input type="text" name="db_user" class="form-control field-tech" value="<%= settings.db_user || '' %>" placeholder="root" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">CONTRASEÑA</label>
                        <div class="input-with-icon">
                            <i class="fas fa-lock"></i>
                            <input type="password" name="db_password" class="form-control" placeholder="••••••••••••" autocomplete="new-password">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    window.__datos = {
        initialLogoUrl: <%- JSON.stringify(settings.portal_logo_url || null) %>,
        urls: {
            updateGeneral: '/admin/update-general',
            testDb: '/admin/test-db',
            home: '/'
        }
    };
</script>
<script src="/static/js/general-page.js"></script>
