
<div class="catalog-container">
    <div class="dashboard-tabs">
        <div class="tab-item" data-tab="fav" data-icon="heart">
            <span class="tab-icon"></span>Favoritos
        </div>
        <div class="tab-item active" data-tab="all" data-icon="tool">
            <span class="tab-icon"></span>Aplicaciones
        </div>
        <% (areas || []).forEach(area => { %>
        <div class="tab-item" data-tab="<%= area.name %>" data-icon="<%= ((area_icons || {})[area.name]) || 'box' %>">
            <span class="tab-icon"></span><%= area.name %>
        </div>
        <% }) %>
    </div>

    <div class="draggable-grid grid-cols-3" id="user-dashboard">
        <% (platforms || []).forEach(platform => { %>
        <div class="app-card" data-area="<%= platform.area ? platform.area.name : '' %>" data-id="<%= platform.id %>">
            <button class="fav-marker" type="button" title="Marcar como favorito" data-action="catalog-toggle-favorite" data-platform-id="<%= platform.id %>">
                <svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"></path></svg>
            </button>
            <div class="app-icon" data-platform-icon="<%= platform.icon || 'box' %>" data-platform-logo="<%= platform.logo_url || '' %>"></div>
            <div class="app-info">
                <div class="app-tag"><%= platform.area ? platform.area.name : '' %></div>
                <div class="app-name"><%= platform.name %></div>
                <div class="app-desc" title="<%= platform.description || '' %>"><%= platform.description || 'Sin descripción disponible.' %></div>
                <div class="card-actions">
                    <% if ((user_platform_ids || []).includes(platform.id)) { %>
                    <div class="d-flex gap-05 w-full mt-05">
                        <button class="btn-launch-main flex-1 border-subtle btn-launch-secondary" type="button" data-action="catalog-open-url" data-url="<%= platform.resources || '#' %>">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                            Docs
                        </button>
                        <button class="btn-launch-main flex-1 btn-launch-compact" type="button" data-action="catalog-open-url" data-url="/platform/visit/<%= platform.id %>">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2 2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                            Abrir
                        </button>
                    </div>
                    <% } else { %>
                    <button class="btn-request-access flex-1" type="button" data-action="catalog-request-access" data-platform-id="<%= platform.id %>" data-platform-name="<%= platform.name %>">Solicitar Acceso</button>
                    <% } %>
                </div>
            </div>
        </div>
        <% }) %>
    </div>

    <div id="grid-empty" class="d-none text-center catalog-empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-15 catalog-empty-icon"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        <h3 class="font-outfit text-primary">Sin aplicaciones en esta categoría</h3>
        <p>No tienes herramientas registradas bajo este filtro.</p>
    </div>

    <div class="pagination-wrap" id="dash-pagination">
        <button class="page-btn" disabled>&lt;</button>
        <button class="page-btn active">1</button>
        <button class="page-btn">2</button>
        <button class="page-btn">&gt;</button>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>window.__catalogUserId = <%= (user && user.id) ? user.id : 0 %>;</script>
<script src="/static/js/catalog.js"></script>
