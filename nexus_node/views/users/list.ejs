<div class="crud-bar d-flex justify-between items-center mb-1 gap-1">
    <div class="search-container flex-1">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="userSearch" class="w-full search-input-with-icon" placeholder="Buscar por nombre o correo...">
    </div>
    <div class="crud-actions d-flex gap-075 items-center">
        <button class="btn btn-action-edit" id="btnAccessUser" data-action="users-open-access" title="Administrar accesos" disabled style="color: var(--primary-color); border-color: var(--primary-color);">
            <i class="fas fa-key" style="margin-right: 6px; font-size: 0.9rem;"></i>
            <span>Accesos</span>
        </button>
        <button class="btn btn-action-edit" id="btnEditUser" data-action="users-edit-selected" title="Modificar seleccionado" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            <span>Modificar</span>
        </button>
        <button class="btn btn-action-delete" id="btnDeleteUser" data-action="users-delete-selected" title="Eliminar seleccionado" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            <span>Eliminar</span>
        </button>
        <div class="v-divider"></div>
        <button class="btn btn-action-new" data-action="users-open-type-modal">
            <i class="fas fa-plus" style="font-size: 1.1rem; margin-right: 8px;"></i>
            <span>Nuevo Usuario</span>
        </button>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="modern-table">
            <thead>
                <tr>
                    <th class="col-cb">
                        <input type="checkbox" id="selectAllUsers" data-action="users-select-all" style="cursor: pointer; width: 16px; height: 16px;">
                    </th>
                    <th>Nombre</th>
                    <th>Correo Electrónico</th>
                    <th>Estado</th>
                    <th>Plataformas</th>
                    <th>Áreas</th>
                    <th>Rol</th>
                </tr>
            </thead>
            <tbody id="usersTableBody"></tbody>
        </table>
    </div>
    <div id="usersPagination" class="pagination-container"></div>
</div>

<div id="editUserModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="editUserModalTitle" aria-hidden="true">
    <div class="modal-content pos-relative">
        <div class="modal-header">
            <h3 id="editUserModalTitle" class="font-outfit fs-xl fw-700 text-primary">Modificar Usuario</h3>
            <button type="button" class="btn-close-modal" aria-label="Cerrar modal" data-action="users-close-edit-modal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <form id="editUserForm" data-premium-validate>
            <input type="hidden" id="editUserNameHidden">
            <div class="mb-15">
                <label class="modal-form-label">Nombre del Usuario</label>
                <div id="editUserNameDisplay" class="fw-700 text-primary" style="font-size: 1.1rem;"></div>
            </div>

            <div class="d-grid grid-2col gap-15 mb-15 items-center">
                <div>
                    <label class="modal-form-label">Rol Asignado</label>
                    <div class="input-with-icon">
                        <i class="fas fa-user-shield"></i>
                        <select id="editUserRole" class="form-control modal-form-input">
                            <option value="Administrador">Administrador</option>
                            <option value="Auditor">Auditor</option>
                            <option value="Usuario">Usuario</option>
                            <option value="Invitado">Invitado</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="modal-form-label">Estado de la Cuenta</label>
                    <div class="input-toggle-wrapper modal-toggle-row">
                        <span class="toggle-title modal-toggle-title" id="editUserStatusText">Cuenta Activa</span>
                        <label class="toggle-switch-ios">
                            <input type="checkbox" id="editUserStatusToggle" checked class="js-status-toggle" data-target-id="editUserStatusText" data-on-label="Cuenta Activa" data-off-label="Cuenta Inactiva">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="mb-2">
                <label class="modal-form-label">Áreas Vinculadas</label>
                <div class="dual-picklist-container">
                    <div class="picklist-wrapper d-flex items-center gap-1">
                        <div class="flex-1">
                            <label class="label-uppercase">Disponibles</label>
                            <select id="editUserAvailable" multiple class="picklist-select">
                                <% (all_areas || []).forEach(area => { %>
                                <option value="<%= area.name %>"><%= area.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="picklist-controls">
                            <button type="button" class="btn-picklist" data-action="users-move-picklist" data-source="editUserAvailable" data-target="editUserSelected"><i class="fas fa-chevron-right"></i></button>
                            <button type="button" class="btn-picklist" data-action="users-move-picklist" data-source="editUserSelected" data-target="editUserAvailable"><i class="fas fa-chevron-left"></i></button>
                        </div>

                        <div class="flex-1">
                            <label class="label-uppercase">Seleccionadas</label>
                            <select id="editUserSelected" multiple class="picklist-select" style="border-color: var(--primary-color);"></select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-between gap-1 mt-2">
                <button type="button" class="btn btn-ghost" data-action="users-close-edit-modal">Cancelar</button>
                <button type="submit" class="btn btn-primary btn-primary-filled" data-action="users-submit-edit">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

<div id="addUserModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="addUserModalTitle" aria-hidden="true">
    <div class="modal-content pos-relative">
        <div class="modal-header">
            <div>
                <h3 id="addUserModalTitle" class="font-outfit fs-xl fw-700 text-primary" style="margin: 0;">Nuevo Usuario</h3>
                <p class="fs-sm text-muted" style="margin: 0.25rem 0 0 0;">Complete los pasos para registrar un nuevo integrante.</p>
            </div>
            <button type="button" class="btn-close-modal" aria-label="Cerrar modal" data-action="users-close-add-modal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="step-indicator mb-2">
            <div class="step-progress-track">
                <div class="step-progress-line" id="addUserStepProgress"></div>
            </div>
            <div class="step-item active" id="addUserStep1_pill">
                <div class="step-pill">
                    <i class="fas fa-user-tag"></i>
                </div>
                <span class="step-label">Perfil</span>
            </div>
            <div class="step-item" id="addUserStep2_pill">
                <div class="step-pill">
                    <i class="fas fa-layer-group"></i>
                </div>
                <span class="step-label">Áreas</span>
            </div>
        </div>

        <form id="addUserForm" data-premium-validate novalidate>
            <div id="addUserStep1" class="modal-step active">
                <div class="mb-15">
                    <label class="modal-form-label">Nombre Completo</label>
                    <div class="input-with-icon">
                        <i class="fas fa-user"></i>
                        <input type="text" id="addUserName" name="name" class="form-control modal-form-input" placeholder="Ej: Juan Perez" required>
                    </div>
                </div>

                <div class="mb-15">
                    <label class="modal-form-label">Correo Electrónico</label>
                    <div class="input-with-icon">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="addUserEmail" name="email" class="form-control modal-form-input" placeholder="usuario@empresa.com" required>
                    </div>
                </div>

                <div class="d-grid grid-2col gap-15 mb-1 items-center">
                    <div>
                        <label class="modal-form-label">Rol Asignado</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user-shield"></i>
                            <select id="addUserRole" name="role" class="form-control modal-form-input">
                                <option value="Administrador">Administrador</option>
                                <option value="Auditor">Auditor</option>
                                <option value="Usuario" selected>Usuario</option>
                                <option value="Invitado">Invitado</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="modal-form-label">Estado Inicial</label>
                        <div class="input-toggle-wrapper modal-toggle-row">
                            <span class="toggle-title modal-toggle-title">Activo</span>
                            <label class="toggle-switch-ios">
                                <input type="checkbox" id="addUserStatusToggle" checked class="js-status-toggle" data-target-selector=".toggle-title" data-on-label="Activo" data-off-label="Inactivo">
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div id="addUserStep2" class="modal-step">
                <div class="form-group">
                    <div class="picklist-modern-container">
                        <div class="picklist-pane">
                            <div class="picklist-pane-header">
                                <i class="fas fa-layer-group"></i> Disponibles
                            </div>
                            <div class="picklist-body scrollable-custom picklist-h-250" id="addUserAvailableList"></div>
                        </div>

                        <div class="picklist-divider">
                            <i class="fas fa-exchange-alt"></i>
                        </div>

                        <div class="picklist-pane">
                            <div class="picklist-pane-header">
                                <i class="fas fa-check-double"></i> Asignadas
                            </div>
                            <div class="picklist-body scrollable-custom picklist-h-250" id="addUserSelectedList"></div>
                        </div>
                    </div>
                    <input type="hidden" name="areas" id="selectedUserAreasInput">
                </div>
            </div>

            <div class="modal-footer modal-footer-actions mt-2">
                <button type="button" class="btn btn-ghost" id="btnAddUserBack" style="display: none;" data-action="users-step-back">Anterior</button>
                <div class="flex-1"></div>
                <button type="button" class="btn btn-ghost" id="btnAddUserCancel" data-action="users-close-add-modal">Cancelar</button>
                <button type="button" class="btn btn-primary btn-primary-filled" id="btnAddUserNext" data-action="users-step-next">Continuar <i class="fas fa-arrow-right ml-05"></i></button>
                <button type="submit" class="btn btn-primary btn-primary-filled" id="btnAddUserSubmit" style="display: none;" data-action="users-submit-new">Finalizar Registro <i class="fas fa-check ml-05"></i></button>
            </div>
        </form>
    </div>
</div>

<div id="userAccessModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="userAccessModalTitle" aria-hidden="true">
    <div class="modal-content pos-relative">
        <div class="modal-header">
            <div>
                <h3 id="userAccessModalTitle" class="font-outfit fs-xl fw-700 text-primary mb-025">Administrar Accesos</h3>
                <p id="accessUserName" class="fs-sm text-muted fw-600"></p>
            </div>
            <button type="button" class="btn-close-modal" aria-label="Cerrar modal" data-action="users-close-access-modal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div id="accessContainer">
            <div class="dual-picklist-container">
                <div class="picklist-wrapper d-flex items-center gap-1">
                    <div class="flex-1">
                        <label class="label-uppercase">Disponibles</label>
                        <select id="accessAvailable" multiple class="picklist-select"></select>
                    </div>

                    <div class="picklist-controls">
                        <button type="button" class="btn-picklist" data-action="users-move-access-picklist" data-source="accessAvailable" data-target="accessSelected"><i class="fas fa-chevron-right"></i></button>
                        <button type="button" class="btn-picklist" data-action="users-move-access-picklist" data-source="accessSelected" data-target="accessAvailable"><i class="fas fa-chevron-left"></i></button>
                    </div>

                    <div class="flex-1">
                        <label class="label-uppercase">Asignadas</label>
                        <select id="accessSelected" multiple class="picklist-select" style="border-color: var(--primary-color);"></select>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer d-flex justify-between gap-1 mt-15" style="border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <button type="button" class="btn btn-ghost" data-action="users-close-access-modal">Cerrar</button>
            <button type="button" class="btn btn-primary btn-primary-filled" data-action="users-save-access">Aplicar Cambios</button>
        </div>
    </div>
</div>

<div id="userTypeModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="userTypeModalTitle" aria-hidden="true">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h3 id="userTypeModalTitle" class="font-outfit fs-xl fw-700 text-primary mb-025">Nuevo Usuario</h3>
                <p class="fs-sm text-muted">Seleccione el método de registro para el nuevo integrante.</p>
            </div>
            <button type="button" class="btn-close-modal" aria-label="Cerrar modal" data-action="users-close-type-modal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="d-grid grid-2col gap-15 mt-1">
            <div class="stat-card modern text-center items-center justify-center p-2" role="button" tabindex="0" style="cursor: pointer; border-width: 2px;" data-action="users-open-local-flow">
                <div class="kpi-icon-wrapper mb-1" style="background: var(--accent-indigo-bg); color: var(--primary-color);">
                    <i class="fas fa-user-plus fa-2x"></i>
                </div>
                <h4 class="font-outfit fs-md fw-700 mb-05">Usuario Local</h4>
                <p class="fs-xs text-muted">Creación manual en la base de datos interna del sistema.</p>
            </div>

            <div class="stat-card modern text-center items-center justify-center p-2" role="button" tabindex="0" style="cursor: pointer; border-width: 2px;" data-action="users-open-ldap-flow">
                <div class="kpi-icon-wrapper mb-1" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
                    <i class="fas fa-network-wired fa-2x"></i>
                </div>
                <h4 class="font-outfit fs-md fw-700 mb-05">Usuario LDAP</h4>
                <p class="fs-xs text-muted">Importación y sincronización desde el Directorio Activo.</p>
            </div>
        </div>

        <div class="modal-footer d-flex justify-center mt-2">
            <button type="button" class="btn btn-ghost" data-action="users-close-type-modal">Cancelar</button>
        </div>
    </div>
</div>

<div id="ldapUserModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="ldapUserModalTitle" aria-hidden="true">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h3 id="ldapUserModalTitle" class="font-outfit fs-xl fw-700 text-primary mb-025">Importar desde LDAP</h3>
                <p class="fs-sm text-muted">Busque el usuario en el directorio activo para su importación.</p>
            </div>
            <button type="button" class="btn-close-modal" aria-label="Cerrar modal" data-action="users-close-ldap-modal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <form id="ldapSearchForm" data-action-submit="ldap-search" data-premium-validate novalidate>
            <div class="form-group mb-15">
                <label class="modal-form-label">Criterio de Búsqueda (SAMAccountName o Email)</label>
                <div class="d-flex gap-05">
                    <div class="input-with-icon flex-1">
                        <i class="fas fa-id-card"></i>
                        <input type="text" id="ldapQuery" class="form-control modal-form-input" placeholder="ej: jsmith o juan.perez@empresa.com" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-primary-filled" style="width: auto; padding: 0 1.5rem;">
                        <i class="fas fa-search"></i>
                        <span>Buscar</span>
                    </button>
                </div>
            </div>
        </form>

        <div id="ldapResultsContainer" class="mt-2 d-none">
            <div class="section-label mb-1">RESULTADOS ENCONTRADOS</div>
            <div id="ldapResultsList" class="d-flex flex-direction-column gap-05"></div>
        </div>

        <div class="modal-footer d-flex justify-between mt-2">
            <button type="button" class="btn btn-ghost" data-action="users-back-ldap-to-type">Regresar</button>
            <button type="button" class="btn btn-ghost" data-action="users-close-ldap-modal">Cerrar</button>
        </div>
    </div>
</div>

<script>
    var allUsersData = <%- JSON.stringify(typeof users_json !== 'undefined' ? users_json : []) %>;
    window.__areaData = <%- JSON.stringify(typeof all_areas_json !== 'undefined' ? all_areas_json : []) %>;
</script>
<script src="/static/js/notifications.js?v=1"></script>
<script src="/static/js/users.js?v=15"></script>
